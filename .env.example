#############################################
# Application
#############################################

APP_NAME=Sentinel
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

#############################################
# API
#############################################

HOST=0.0.0.0
PORT=8000

#############################################
# Security
#############################################

SECRET_KEY=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

#############################################
# PostgreSQL
#############################################

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinel
POSTGRES_USER=
POSTGRES_PASSWORD=

DATABASE_URL=

#############################################
# Redis
#############################################

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

#############################################
# Vector Database
#############################################

VECTOR_DB=qdrant

QDRANT_HOST=localhost
QDRANT_PORT=6333

MILVUS_HOST=localhost
MILVUS_PORT=19530

#############################################
# Ollama
#############################################

OLLAMA_HOST=http://localhost:11434

#############################################
# OpenAI
#############################################

OPENAI_API_KEY=

#############################################
# GitHub
#############################################

GITHUB_TOKEN=

#############################################
# Observability
#############################################

PROMETHEUS_PORT=9090

#############################################
# Celery
#############################################

CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

#############################################
# File Storage
#############################################

UPLOAD_DIR=uploads

#############################################
# Feature Flags
#############################################

ENABLE_CACHE=true
ENABLE_AI=true
ENABLE_SECURITY_SCAN=true
